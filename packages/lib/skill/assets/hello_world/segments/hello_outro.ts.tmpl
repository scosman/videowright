import { defineSegment } from 'videowright';

let host: HTMLElement | null = null;

export default defineSegment({
  id: 'hello-outro',
  voiceover: 'Thanks for watching. Start building your video by editing the segments.',

  mount(el) {
    host = el;
    el.innerHTML = `
      <div style="
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        font-family: system-ui, -apple-system, sans-serif;
      ">
        <h1 style="font-size: 3rem; margin: 0; opacity: 0;" data-ref="thanks">Thanks for watching</h1>
        <p style="font-size: 1.25rem; margin-top: 1.5rem; opacity: 0; max-width: 600px; text-align: center; line-height: 1.6;" data-ref="cta">
          Edit the segments in <code style="background: rgba(255,255,255,0.2); padding: 0.2em 0.4em; border-radius: 4px;">segments/</code> to start building your video.
        </p>
      </div>
    `;
  },

  async play(ctx) {
    const thanks = host!.querySelector('[data-ref="thanks"]') as HTMLElement;
    const cta = host!.querySelector('[data-ref="cta"]') as HTMLElement;

    // Animate heading in
    thanks.animate(
      [{ opacity: 0, transform: 'scale(0.9)' }, { opacity: 1, transform: 'scale(1)' }],
      { duration: 500, fill: 'forwards', easing: 'ease-out' },
    );

    await ctx.hold(500);

    // Animate call-to-action in
    cta.animate(
      [{ opacity: 0 }, { opacity: 1 }],
      { duration: 400, fill: 'forwards' },
    );

    // No waitForNext -- this is the last segment.
    // play() resolves immediately after the animation.
    // The player shows "end of timeline" in the HUD.
  },

  unmount() {
    host = null;
  },
});
