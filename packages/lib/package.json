{
	"name": "videowright",
	"version": "0.0.0",
	"type": "module",
	"description": "Compose browser-native video segments with any web technology",
	"license": "MIT",
	"bin": {
		"videowright": "./dist/cli/bin.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./cli": {
			"types": "./dist/cli/index.d.ts",
			"import": "./dist/cli/index.js"
		}
	},
	"files": ["dist", "skill", "src/cli/entry"],
	"scripts": {
		"build": "tsc -b",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "npm run build && npx playwright test"
	},
	"dependencies": {
		"tsx": "^4.19.0",
		"vite": "^6.3.5"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.6.2",
		"jsdom": "^29.1.1",
		"vitest": "^3.1.3",
		"yaml": "^2.8.4"
	}
}
